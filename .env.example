# Teleapo Backend API（連絡先抽出を委譲）
# 04_teleapo_api がデプロイされたバックエンドURL
TELEAPO_API_BASE=https://04teleapoapi-kokisugiyama12-6776s-projects.vercel.app
# 管理者から発行されたライセンスキー（tlap_ で始まる）
TELEAPO_LICENSE_KEY=

# Google OAuth (required for Spreadsheet export)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL (adjust for production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
